<Window
    x:Class="MinimalFirewall.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MinimalFirewall"
    Title="Minimal Firewall">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar area -->
        <Grid x:Name="AppTitleBar" Height="32" Grid.Row="0"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="AppTitle" Text="Minimal Firewall"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Lockdown button -->
            <Button x:Name="LockdownButton" Grid.Column="1"
                    Width="36" Height="28" Margin="0,2,4,2"
                    Click="LockdownButton_Click"
                    ToolTipService.ToolTip="Toggle Lockdown Mode"
                    Style="{StaticResource AccentButtonStyle}">
                <FontIcon x:Name="LockdownIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" FontSize="14" />
            </Button>

            <!-- Rescan button -->
            <Button x:Name="RescanButton" Grid.Column="2"
                    Width="36" Height="28" Margin="0,2,8,2"
                    Click="RescanButton_Click"
                    ToolTipService.ToolTip="Rescan Firewall Rules">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Main NavigationView -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="160"
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Rules" Content="Rules">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="WildcardRules" Content="Wildcard Rules">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE773;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Audit" Content="Audit">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Groups" Content="Groups">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF168;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="LiveConnections" Content="Live">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEC05;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Settings" Content="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Status bar at bottom of pane -->
            <NavigationView.PaneFooter>
                <StackPanel Margin="8,0,8,8">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="" FontSize="10"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="PendingCountBadge"
                               Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <!-- Content Frame -->
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Notification overlay (shown on top) -->
        <Grid x:Name="NotificationOverlay" Grid.Row="1"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,16,16" IsHitTestVisible="False">
        </Grid>
    </Grid>
</Window>
