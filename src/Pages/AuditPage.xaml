<Page
    x:Class="MinimalFirewall.Pages.AuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="RebuildBaselineButton" Content="Rebuild Baseline"
                    ToolTipService.ToolTip="Unarchives all hidden rules, making them visible again."
                    Click="RebuildBaselineButton_Click" />
            <CheckBox x:Name="QuarantineCheckBox"
                      Grid.Column="1"
                      Content="Quarantine Mode" Margin="12,0,0,0"
                      ToolTipService.ToolTip="Automatically archive new foreign rules."
                      Click="QuarantineCheckBox_Click" />
            <AutoSuggestBox Grid.Column="3"
                            x:Name="AuditSearchBox"
                            PlaceholderText="Search changes…"
                            Width="280" QueryIcon="Find"
                            TextChanged="AuditSearchBox_TextChanged" />
        </Grid>

        <!-- Changes grid -->
        <controls:DataGrid
            x:Name="AuditDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            SelectionMode="Extended"
            SelectionChanged="AuditDataGrid_SelectionChanged"
            Sorting="AuditDataGrid_Sorting">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Publisher" Binding="{Binding Rule.Publisher}" Width="140" />
                <controls:DataGridTextColumn Header="Name" Binding="{Binding Rule.Name}" Width="200" />
                <controls:DataGridTextColumn Header="Status" Binding="{Binding Type}" Width="100" />
                <controls:DataGridTextColumn Header="Protocol" Binding="{Binding Rule.ProtocolName}" Width="80" />
                <controls:DataGridTextColumn Header="Local Ports" Binding="{Binding Rule.LocalPorts}" Width="90" />
                <controls:DataGridTextColumn Header="Remote Ports" Binding="{Binding Rule.RemotePorts}" Width="90" />
                <controls:DataGridTextColumn Header="Program" Binding="{Binding Rule.ApplicationName}" Width="160" />
                <controls:DataGridTextColumn Header="Service" Binding="{Binding Rule.ServiceName}" Width="120" />
                <controls:DataGridTextColumn Header="Group" Binding="{Binding Rule.Grouping}" Width="120" />
                <controls:DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="130" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Splitter -->
        <Border Grid.Row="2" Height="4" />

        <!-- Diff panel -->
        <Border Grid.Row="3"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4">
            <ScrollViewer>
                <TextBlock x:Name="DiffTextBlock"
                           Padding="12"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12" />
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="AuditStatusText" Grid.Row="4"
                   Margin="0,4,0,0" FontSize="11"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
