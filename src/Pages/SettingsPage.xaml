<Page
    x:Class="MinimalFirewall.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="20" MaxWidth="640">

            <!-- Appearance -->
            <StackPanel>
                <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="AutoThemeSwitch" Header="Auto theme (follows system)"
                                  Toggled="AutoThemeSwitch_Toggled" />
                    <ToggleSwitch x:Name="DarkModeSwitch" Header="Dark mode"
                                  Toggled="DarkModeSwitch_Toggled" />
                    <ToggleSwitch x:Name="ShowAppIconsSwitch" Header="Show application icons"
                                  Toggled="ShowAppIconsSwitch_Toggled" />
                </StackPanel>
            </StackPanel>

            <!-- Behaviour -->
            <StackPanel>
                <TextBlock Text="Behaviour" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="CloseToTraySwitch" Header="Close to system tray"
                                  Toggled="Save_Toggled" />
                    <ToggleSwitch x:Name="StartOnStartupSwitch" Header="Start with Windows"
                                  Toggled="StartOnStartupSwitch_Toggled" />
                    <ToggleSwitch x:Name="PopupsSwitch" Header="Show popup notifications"
                                  Toggled="Save_Toggled" />
                    <ToggleSwitch x:Name="LoggingSwitch" Header="Enable activity logging"
                                  Toggled="LoggingSwitch_Toggled" />
                    <ToggleSwitch x:Name="AutoAllowSystemTrustedSwitch"
                                  Header="Auto-allow system trusted applications"
                                  Toggled="Save_Toggled" />
                    <ToggleSwitch x:Name="AuditAlertsSwitch"
                                  Header="Alert on foreign firewall rule changes"
                                  Toggled="Save_Toggled" />
                </StackPanel>
            </StackPanel>

            <!-- Traffic monitor -->
            <StackPanel>
                <TextBlock Text="Traffic Monitor" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <ToggleSwitch x:Name="TrafficMonitorSwitch" Header="Enable live connections monitor"
                              Toggled="TrafficMonitorSwitch_Toggled" />
            </StackPanel>

            <!-- Auto refresh -->
            <StackPanel>
                <TextBlock Text="Auto Refresh" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Refresh interval (minutes):" VerticalAlignment="Center" />
                    <NumberBox x:Name="AutoRefreshBox"
                               Minimum="1" Maximum="60" SpinButtonPlacementMode="Inline"
                               Width="150"
                               ValueChanged="AutoRefreshBox_ValueChanged" />
                </StackPanel>
            </StackPanel>

            <!-- Maintenance -->
            <StackPanel>
                <TextBlock Text="Maintenance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <ItemsControl x:Name="MaintenanceButtons">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Items>
                        <Button x:Name="ManagePublishersButton" Content="Manage Publishers…" Margin="0,0,8,8"
                                Click="ManagePublishersButton_Click" />
                        <Button x:Name="CleanUpOrphanedButton" Content="Clean Orphaned Rules" Margin="0,0,8,8"
                                Click="CleanUpOrphanedButton_Click" />
                        <Button x:Name="ExportRulesButton" Content="Export Rules…" Margin="0,0,8,8"
                                Click="ExportRulesButton_Click" />
                        <Button x:Name="ImportMergeButton" Content="Import (Merge)…" Margin="0,0,8,8"
                                Click="ImportMergeButton_Click" />
                        <Button x:Name="ImportReplaceButton" Content="Import (Replace)…" Margin="0,0,8,8"
                                Click="ImportReplaceButton_Click" />
                        <Button x:Name="DeleteAllRulesButton" Content="Delete All MFW Rules" Margin="0,0,8,8"
                                Click="DeleteAllRulesButton_Click" />
                        <Button x:Name="RevertFirewallButton" Content="Revert Firewall to Defaults" Margin="0,0,8,8"
                                Click="RevertFirewallButton_Click" />
                        <Button x:Name="OpenFirewallButton" Content="Open Windows Firewall" Margin="0,0,8,8"
                                Click="OpenFirewallButton_Click" />
                        <Button x:Name="OpenAppDataButton" Content="Open App Data Folder" Margin="0,0,8,8"
                                Click="OpenAppDataButton_Click" />
                        <Button x:Name="CheckUpdatesButton" Content="Check for Updates" Margin="0,0,8,8"
                                Click="CheckUpdatesButton_Click" />
                        <Button x:Name="ExportDiagnosticButton" Content="Export Diagnostic (Rules + Config)…" Margin="0,0,8,8"
                                Click="ExportDiagnosticButton_Click" />
                    </ItemsControl.Items>
                </ItemsControl>
            </StackPanel>

            <!-- About -->
            <StackPanel>
                <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <StackPanel Spacing="4">
                    <TextBlock x:Name="VersionLabel" Text="Version …" />
                    <HyperlinkButton x:Name="HelpLink"
                                     Content="Documentation / Help"
                                     NavigateUri="https://github.com/deminimis/minimalfirewall/wiki" />
                    <HyperlinkButton x:Name="ReportProblemLink"
                                     Content="Report a Problem"
                                     NavigateUri="https://github.com/deminimis/minimalfirewall/issues" />
                    <HyperlinkButton x:Name="ForumLink"
                                     Content="Forum / Discussions"
                                     NavigateUri="https://github.com/deminimis/minimalfirewall/discussions" />
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
