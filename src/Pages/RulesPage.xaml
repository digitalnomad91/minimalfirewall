<Page
    x:Class="MinimalFirewall.Pages.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MinimalFirewall"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CreateRuleButton"
                    Content="Create New Rule…"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="CreateRuleButton_Click" />

            <AutoSuggestBox Grid.Column="2"
                            x:Name="SearchBox"
                            PlaceholderText="Search rules…"
                            Width="280"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged" />
        </Grid>

        <!-- Filter checkboxes -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
            <CheckBox x:Name="ProgramFilter" Content="Programs" IsChecked="True"
                      Click="Filter_Changed" />
            <CheckBox x:Name="ServiceFilter" Content="Services" IsChecked="True"
                      Click="Filter_Changed" />
            <CheckBox x:Name="UwpFilter" Content="UWP" IsChecked="True"
                      Click="Filter_Changed" />
            <CheckBox x:Name="WildcardFilter" Content="Wildcards" IsChecked="True"
                      Click="Filter_Changed" />
            <CheckBox x:Name="SystemFilter" Content="System" IsChecked="False"
                      Click="Filter_Changed" />
        </StackPanel>

        <!-- Rules DataGrid -->
        <controls:DataGrid
            x:Name="RulesDataGrid"
            Grid.Row="2"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            CanUserReorderColumns="True"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            SelectionMode="Extended"
            Sorting="RulesDataGrid_Sorting"
            RightTapped="RulesDataGrid_RightTapped"
            DoubleTapped="RulesDataGrid_DoubleTapped">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                <controls:DataGridTextColumn Header="Inbound" Binding="{Binding InboundStatus}" Width="80" />
                <controls:DataGridTextColumn Header="Outbound" Binding="{Binding OutboundStatus}" Width="80" />
                <controls:DataGridTextColumn Header="Protocol" Binding="{Binding ProtocolName}" Width="70" />
                <controls:DataGridTextColumn Header="Local Ports" Binding="{Binding LocalPorts}" Width="90" />
                <controls:DataGridTextColumn Header="Remote Ports" Binding="{Binding RemotePorts}" Width="90" />
                <controls:DataGridTextColumn Header="Program" Binding="{Binding ApplicationName}" Width="160" />
                <controls:DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="120" />
                <controls:DataGridTextColumn Header="Profiles" Binding="{Binding Profiles}" Width="80" />
                <controls:DataGridTextColumn Header="Group" Binding="{Binding Grouping}" Width="120" />
                <controls:DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Status / count -->
        <TextBlock x:Name="RulesStatusText" Grid.Row="3"
                   Margin="0,4,0,0" FontSize="11"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Context Menu -->
        <Grid.ContextFlyout>
            <MenuFlyout x:Name="RulesContextMenu">
                <MenuFlyoutSubItem Text="Allow">
                    <MenuFlyoutItem Text="Allow Outbound" Click="AllowOutbound_Click" />
                    <MenuFlyoutItem Text="Allow Inbound" Click="AllowInbound_Click" />
                    <MenuFlyoutItem Text="Allow All" Click="AllowAll_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem Text="Block">
                    <MenuFlyoutItem Text="Block Outbound" Click="BlockOutbound_Click" />
                    <MenuFlyoutItem Text="Block Inbound" Click="BlockInbound_Click" />
                    <MenuFlyoutItem Text="Block All" Click="BlockAll_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Edit Rule…" Click="EditRule_Click" />
                <MenuFlyoutItem Text="Delete Rule" Click="DeleteRule_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Open File Location" Click="OpenFileLocation_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Copy Details" Click="CopyDetails_Click" />
            </MenuFlyout>
        </Grid.ContextFlyout>
    </Grid>
</Page>
