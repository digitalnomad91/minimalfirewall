<Page
    x:Class="MinimalFirewall.Pages.WildcardRulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button x:Name="AddRuleButton" Content="Add Rule…"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="AddRuleButton_Click" />
            <Button x:Name="EditRuleButton" Content="Edit Rule…"
                    Click="EditRuleButton_Click" />
            <Button x:Name="DeleteRuleButton" Content="Delete Rule"
                    Click="DeleteRuleButton_Click" />
        </StackPanel>

        <!-- Wildcard rules grid -->
        <controls:DataGrid
            x:Name="WildcardDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            SelectionMode="Extended">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Folder" Binding="{Binding FolderPath}" Width="*" />
                <controls:DataGridTextColumn Header="Exe Name" Binding="{Binding ExeName}" Width="140" />
                <controls:DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100" />
                <controls:DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" />
                <controls:DataGridTextColumn Header="Remote Ports" Binding="{Binding RemotePorts}" Width="100" />
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="2"
                   Margin="0,4,0,0" FontSize="11"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </Grid>
</Page>
